{
  "metadata_shortlist": 100,
  "final_recommendations": 20,
  "defaults_are_fallbacks_not_minimums": true,
  "workflow_profiles": {
    "comprehensive": {"stop_after": "recommendation", "shortlist_target": 100, "final_target": 20},
    "focused": {"counts": "chosen_by_codex_for_current_question", "stop_after": "smallest_sufficient_stage"},
    "incremental": {"reuse_parent_artifacts": true, "search_only_evidence_gap": true},
    "metadata_only": {"stop_after": "metadata_or_shortlist", "fulltext_required": false}
  },
  "cache_policy": "reuse",
  "fulltext_workers": 8,
  "http_channel_concurrency": {
    "arxiv": 1,
    "openreview": 1,
    "openreview_hard_ceiling": 3,
    "acm": 1,
    "semantic_scholar": 2,
    "openalex": 4,
    "dblp": 1,
    "default_host": 2,
    "host-aclanthology.org": 6,
    "host-openaccess.thecvf.com": 6,
    "environment_override": "RECOMMEND_PAPERS_HTTP_CONCURRENCY",
    "cooldown_requeue_wait_cap_seconds": 180,
    "cooldown_requeue_workers": 1
  },
  "deep_read_parallelism": {
    "default_mode": "one_external_claude_process_per_paper",
    "claude_processes": "one_fresh_process_per_reading_paper",
    "max_concurrency": 16,
    "scheduling": "bounded_pipeline_refill_on_completion",
    "fallback_when": ["claude_unavailable", "user_explicitly_disables_claude"],
    "fallback_mode": "exactly_three_direct_codex_batch_subagents",
    "fallback_batch_count": 3,
    "fallback_per_paper_artifacts": false,
    "user_disabled_claude_default_scope": "conversation",
    "user_disabled_claude_is_sticky": true,
    "user_silence_clears_preference": false,
    "explicit_reenable_required": true
  },
  "single_paper_read": {
    "required_for_every_acquired_full_text_in_default_claude_mode": true,
    "language": "zh-CN",
    "cache_by_full_text_sha256": true
  },
  "storage": {
    "state_root": "${XDG_STATE_HOME:-~/.local/state}/taste/recommend-papers",
    "runs": "${XDG_STATE_HOME:-~/.local/state}/taste/recommend-papers/runs",
    "cache": "${XDG_CACHE_HOME:-~/.cache}/taste/recommend-papers",
    "metadata_cache": "${XDG_CACHE_HOME:-~/.cache}/taste/recommend-papers/metadata",
    "visible_cache_directories": ["metadata", "fulltext"],
    "allow_repository_writes": false
  },
  "baseline_channels": [
    {
      "type": "venue",
      "name": "NeurIPS",
      "aliases": ["NIPS"],
      "venue_id": "neurips"
    },
    {
      "type": "venue",
      "name": "ICLR",
      "venue_id": "iclr"
    },
    {
      "type": "venue",
      "name": "ICML",
      "venue_id": "icml"
    },
    {
      "type": "arxiv",
      "name": "arXiv"
    }
  ],
  "adaptive_channel_selection": {
    "required_in_comprehensive_default_scope": true,
    "minimum_additional_channels": 1,
    "maximum_additional_channels": 3,
    "record_decisions": true,
    "selection_basis": "highest_expected_value_for_research_topic"
  },
  "metadata_cache_max_age_days": 7,
  "retrieval_windows": {
    "conference": {
      "mode": "latest_available_metadata_year",
      "year_count": 1,
      "complete_catalog_required": true,
      "result_limit_allowed": false
    },
    "arxiv": {
      "mode": "trailing_calendar_months",
      "months": 6,
      "inclusive": true,
      "complete_category_day_shards_required": true,
      "cache_layout": "metadata/arxiv/<category>/<YYYY-MM-DD>.json",
      "default_ai_categories": ["cs.AI", "cs.LG", "stat.ML", "cs.CL", "cs.CV", "cs.IR", "cs.RO", "eess.SY", "cs.MA", "cs.NE"]
    },
    "biorxiv": {
      "mode": "trailing_calendar_months",
      "months": 6,
      "inclusive": true,
      "complete_daily_shards_required": true,
      "cache_layout": "metadata/biorxiv/<YYYY-MM-DD>.json",
      "all_categories": true,
      "result_limit_allowed": false,
      "recent_recheck_days": 3,
      "recent_recheck_max_age_days": 1
    }
  },
  "final_score_dimensions": {
    "match_score": 10,
    "transferability_score": 10
  }
}
